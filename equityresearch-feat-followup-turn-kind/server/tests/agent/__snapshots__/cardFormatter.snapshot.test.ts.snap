0px;font-weight:600;">RR</td><td style="padding:8px 10px;">Richtech Robotics Inc.</td><td style="padding:8px 10px;font-size:12px;">time-not-supplied</td><td style="padding:8px 10px;font-size:12px;">Mar/2026</td><td style="padding:8px 10px;"></td><td style="padding:8px 10px;">($0.03)</td></tr><tr style="border-bottom:1px solid #f3f4f6;"><td style="padding:8px 10px;font-weight:600;">AFJK</td><td style="padding:8px 10px;">Aimei Health Technology Co., Ltd</td><td style="padding:8px 10px;font-size:12px;">time-not-supplied</td><td style="padding:8px 10px;font-size:12px;">Mar/2026</td><td style="padding:8px 10px;"></td><td style="padding:8px 10px;"></td></tr><tr style="border-bottom:1px solid #f3f4f6;"><td style="padding:8px 10px;font-weight:600;">CAAS</td><td style="padding:8px 10px;">China Automotive Systems, Inc.</td><td style="padding:8px 10px;font-size:12px;">time-not-supplied</td><td style="padding:8px 10px;font-size:12px;">Mar/2026</td><td style="padding:8px 10px;"></td><td style="padding:8px 10px;"></td></tr><tr style="border-bottom:1px solid #f3f4f6;"><td style="padding:8px 10px;font-weight:600;">LVO</td><td style="padding:8px 10px;">LiveOne, Inc.</td><td style="padding:8px 10px;font-size:12px;">time-not-supplied</td><td style="padding:8px 10px;font-size:12px;">Mar/2026</td><td style="padding:8px 10px;"></td><td style="padding:8px 10px;">($0.31)</td></tr><tr style="border-bottom:1px solid #f3f4f6;"><td style="padding:8px 10px;font-weight:600;">DSWL</td><td style="padding:8px 10px;">Deswell Industries, Inc.</td><td style="padding:8px 10px;font-size:12px;">time-not-supplied</td><td style="padding:8px 10px;font-size:12px;">Mar/2026</td><td style="padding:8px 10px;"></td><td style="padding:8px 10px;"></td></tr><tr style="border-bottom:1px solid #f3f4f6;"><td style="padding:8px 10px;font-weight:600;">LPSN</td><td style="padding:8px 10px;">LivePerson, Inc.</td><td style="padding:8px 10px;font-size:12px;">time-not-supplied</td><td style="padding:8px 10px;font-size:12px;">Mar/2026</td><td style="padding:8px 10px;"></td><td style="padding:8px 10px;">($1.02)</td></tr><tr style="border-bottom:1px solid #f3f4f6;"><td style="padding:8px 10px;font-weight:600;">SEGG</td><td style="padding:8px 10px;">Sports Entertainment Gaming Global Corporation </td><td style="padding:8px 10px;font-size:12px;">time-not-supplied</td><td style="padding:8px 10px;font-size:12px;">Mar/2026</td><td style="padding:8px 10px;"></td><td style="padding:8px 10px;"></td></tr><tr style="border-bottom:1px solid #f3f4f6;"><td style="padding:8px 10px;font-weight:600;">DTSS</td><td style="padding:8px 10px;">Datasea Intelligent Technology Ltd.</td><td style="padding:8px 10px;font-size:12px;">time-not-supplied</td><td style="padding:8px 10px;font-size:12px;">Mar/2026</td><td style="padding:8px 10px;"></td><td style="padding:8px 10px;"></td></tr><tr style="border-bottom:1px solid #f3f4f6;"><td style="padding:8px 10px;font-weight:600;">LRHC</td><td style="padding:8px 10px;">La Rosa Holdings Corp.</td><td style="padding:8px 10px;font-size:12px;">time-not-supplied</td><td style="padding:8px 10px;font-size:12px;">Mar/2026</td><td style="padding:8px 10px;"></td><td style="padding:8px 10px;"></td></tr><tr style="border-bottom:1px solid #f3f4f6;"><td style="padding:8px 10px;font-weight:600;">BTTC</td><td style="padding:8px 10px;">Black Titan Corp</td><td style="padding:8px 10px;font-size:12px;">time-not-supplied</td><td style="padding:8px 10px;font-size:12px;">Mar/2026</td><td style="padding:8px 10px;"></td><td style="padding:8px 10px;"></td></tr></table>
      
