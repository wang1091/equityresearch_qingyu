# EquityResearch — single environment file.
#
# The server reads ONLY this file (server/index.ts), per-machine + gitignored.
#   cp .env.example .env   then fill in values.
# pm2 injects NODE_ENV/PORT in production; anything unset here falls back to the
# documented defaults in server/upstreamConfig.ts.
#
# Topology (EC2 nginx): the equity backend runs on :5003; every other backend
# runs on a localhost PORT that nginx also fronts behind a public domain. Point
# the vars below at the LOCAL ports. Two upstreams (NEWS, VALUATION) auto-fail
# over to their public domain when the local port is down; the rest are
# local-only (no failover wrapper) — see the markers below.

NODE_ENV=development
PORT=5003

# ── Frontend links — BUILD-TIME (Vite bakes these into the client bundle) ─────
# MUST be public domains (the browser can't reach the server's localhost ports).
# Only used by `vite build`, never at runtime.
VITE_CHECKIT_HOME_URL=https://checkitanalytics.com
VITE_SMARTNEWS_BASE_URL=https://smartnews.checkitanalytics.com
VITE_RUMORCHECK_BASE_URL=https://rumorcheck.checkitanalytics.com
VITE_KEYMETRICS_BASE_URL=https://keymetrics.checkitanalytics.com
VITE_VALUATION_BASE_URL=https://valuation.checkitanalytics.com
VITE_FDA_CALENDAR_BASE_URL=https://fdacalendar.checkitanalytics.com
VITE_INDUSTRY_ANALYSIS_BASE_URL=https://industryanalysis.checkitanalytics.com

# ── Backend upstreams — RUNTIME (server-side fetches), pointed at LOCAL ports ──
#
# [auto-failover] local primary → public domain automatically when local is down
#   (server/upstreamFetch.ts). The public fallback URL need not be set.
NEWS_API_BASE_URL=http://127.0.0.1:5000        # SmartNews backend (:5000) → smartnews.checkitanalytics.com
VALUATION_API_URL=http://127.0.0.1:8503        # Valuation JSON API (:8503) → valuation.checkitanalytics.com/api
PERFORMANCE_API_URL=http://127.0.0.1:8502      # Keymetrics (:8502) → keymetrics.checkitanalytics.com
STOCK_PICKER_API_URL=http://127.0.0.1:5656     # Stockpick (:5656) → stockpick.checkitanalytics.com
TRENDING_API_URL=http://127.0.0.1:5656         # same backend as stockpick (:5656) → stockpick.checkitanalytics.com
FDA_API_BASE_URL=http://127.0.0.1:5002         # FDA calendar (:5002) → fdacalendar.checkitanalytics.com
# Explicit public fallbacks (optional; these are also the resolver defaults):
# SMARTNEWS_API_URL=https://smartnews.checkitanalytics.com
# VALUATION_FALLBACK_URL=https://valuation.checkitanalytics.com
# PERFORMANCE_FALLBACK_URL=https://keymetrics.checkitanalytics.com
# STOCK_PICKER_FALLBACK_URL=https://stockpick.checkitanalytics.com
# TRENDING_FALLBACK_URL=https://stockpick.checkitanalytics.com
# FDA_FALLBACK_URL=https://fdacalendar.checkitanalytics.com
#
# [local-only] no failover wrapper — if the local service is down the feature
#   degrades. (All run on the same box, so box up ⇒ service up.)
COMPETITIVE_FLASK_URL=http://127.0.0.1:8081    # Industry Analysis / Porter (:8081)

# ── RUMOR ─────────────────────────────────────────────────────────────────────
# Primary = internal chatbot on :3000 (rumorcheck is WordPress-auth-protected on
# its public domain, so we hit it INTERNALLY to bypass auth — needs the token).
RUMOR_CHATBOT_INTERNAL_URL=http://127.0.0.1:3000
RUMORCHECK_INTERNAL_TOKEN=
# Legacy rumor fallback = ${API_BASE_URL}/api/detect-rumor (SmartNews :5000).
# API_BASE_URL is also the NEWS alt-source, but NEWS_API_BASE_URL takes priority.
API_BASE_URL=http://127.0.0.1:5000

# ── Secrets ───────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
GEMINI_API_KEY=                # set to enable the DeepSeek -> Gemini failover
PERPLEXITY_API_KEY=

# ── Intent-classifier LLM (optional; defaults to DeepSeek) ────────────────────
# OpenAI-compatible /chat/completions. Point at a local model (Ollama/LM Studio/
# vLLM) for free routing iteration. CLASSIFIER_LLM_* take precedence over LLM_*.
# CLASSIFIER_LLM_BASE_URL=http://localhost:11434/v1
# CLASSIFIER_LLM_MODEL=qwen2.5:14b
# CLASSIFIER_LLM_API_KEY=
# CLASSIFIER_LLM_MAX_TOKENS=600
# CLASSIFIER_LLM_TIMEOUT_MS=15000

# ── Competitive / industry (Porter) — optional overrides ──────────────────────
# COMPETITIVE_PROVIDER=node                    # node = DeepSeek (default); flask = GPT-4o service (:8081)
# COMPETITIVE_AUTO_FAILOVER=true
# COMPETITIVE_CACHE_TTL_MS=1800000
# COMPETITIVE_CACHE_MAX=500
